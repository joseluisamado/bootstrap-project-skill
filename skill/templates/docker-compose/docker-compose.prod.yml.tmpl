# Production overlay for docker-compose.yml.
#
# Usage (substitute the version you built):
#
#   VERSION=$(cat VERSION) docker compose \
#       -f docker-compose.yml -f docker-compose.prod.yml up -d
#
# The base file's `api` service is reused; this overlay pins the image to a
# versioned tag (matching what `make build-prod` produced) and adds the
# frontend service that serves the static bundle.

services:
{{#if has_backend}}
  api:
    image: {{project_slug}}-api:${VERSION:-latest}
    pull_policy: never  # local-only build for now; remove once a registry is wired
{{/if}}

{{#if has_frontend}}
  frontend-prod:
    image: {{project_slug}}-frontend:${VERSION:-latest}
    pull_policy: never
    restart: unless-stopped
    ports:
      - "${HTTP_PORT:-8080}:80"
    depends_on:
      api:
        condition: service_healthy
    healthcheck:
      test: ["CMD", "curl", "-fsS", "http://localhost/"]
      interval: 30s
      timeout: 5s
      retries: 3
{{/if}}
